# Python caches
__pycache__/
*.pyc
*.pyo

# Ruff cache
.ruff_cache/

# IDE
.idea/

# Runtime data
data/
db/

# Keep runtime directory skeletons in repo
!data/
data/*
!data/.gitkeep
!data/assets/
data/assets/*
!data/assets/.gitkeep
!data/exports/
data/exports/*
!data/exports/.gitkeep
!data/previews/
data/previews/*
!data/previews/.gitkeep

!db/
db/*
!db/.gitkeep

# Build artifacts
build/gui_main/
build/installer/output/
dist/

# Keep publishable packaged outputs
!dist/
dist/*
!dist/STRepertory.exe

!build/installer/output/
build/installer/output/*
!build/installer/output/STRepertory-setup.exe

# Windows noise
Thumbs.db
Desktop.ini
